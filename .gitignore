# =============================================================================
# SLDPC .gitignore
# =============================================================================

# ----- Model weights & large binaries (NEVER commit) -------------------------
*.pth
*.ckpt
*.bin
*.safetensors
*.pt

# TITAN / PRISM / CONCH weights must be downloaded by the user.
# The MahmoodLab/ directory (downloaded from HuggingFace) is licensed
# CC-BY-NC-ND 4.0 and MUST NOT be redistributed.
MahmoodLab/
prism_weights/
conch_weights/

# ----- Feature files ---------------------------------------------------------
*.pkl
*.npy
*.npz
*.h5
*.hdf5
features/
feature_bank/

# ----- Raw WSI & intermediate image products ---------------------------------
*.svs
*.tiff
*.tif
*.ndpi
*.mrxs
raw_svs/
heatmap_output/

# ----- Checkpoints & runs ----------------------------------------------------
checkpoints/
runs/
tb_logs/
wandb/
lightning_logs/

# ----- Experiment outputs ----------------------------------------------------
ablation_results/
results/
outputs/

# ----- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ----- Virtual envs ----------------------------------------------------------
.venv/
.venv_release_check/
venv/
env/
.conda/

# ----- IDE -------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Logs ------------------------------------------------------------------
*.log
logs/
!docs/*.log

# ----- Jupyter ---------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_meta

# ----- Temp ------------------------------------------------------------------
tmp/
temp/
scratch/

# ----- Internal handoff / planning docs (not for public release) -------------
HANDOFF*.md
REFACTOR_PLAN*.md
*_diagnosis.md
*_alignment_plan.md

